{
  "name": "flow-builder",
  "version": "0.1.0",
  "type": "module",
  "description": "⚡︎ A modular node-based pipeline builder built with React, TypeScript, and Vite.",
  "author": {
    "name": "Chitrank agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://wwww.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/flow-builder"
  },
  "scripts": {
    "dev": "vite",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "setup": "bash scripts/install.sh",
    "clean-setup": "pnpm run obliviate && pnpm run setup",
    "build": "tsc --noEmit && vite build",
    "build:full": "bash scripts/build.sh",
    "obliviate": "bash scripts/obliviate.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@xyflow/react": "^12.10.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-adsense": "^1.2.0",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-radar": "^0.10.1"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "vite": "^7.3.1"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched .",
      "biome lint --error-on-warnings ."
    ]
  }
}
